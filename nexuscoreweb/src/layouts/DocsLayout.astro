---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/astro/docs/Sidebar.astro';
import TableOfContents from '../components/astro/docs/TableOfContents.astro';
import type { SupportedLanguage } from '../i18n/utils';

interface Props {
  doc: CollectionEntry<'docs'> | CollectionEntry<'docs-zh'>;
  headings: { depth: number; slug: string; text: string }[];
  lang?: SupportedLanguage;
}

const { doc, headings, lang = 'en' } = Astro.props;
const { title, description } = doc.data;

// Get all docs for sidebar - use correct collection based on lang
const allDocs = lang === 'zh'
  ? await getCollection('docs-zh')
  : await getCollection('docs');

// Language prefix for links
const langPrefix = lang === 'zh' ? '/zh' : '';
---

<BaseLayout title={`${title} | Nexus Core Docs`} description={description} hasDocsSidebar={true}>
  <div class="flex items-start min-h-screen bg-dark-bg">
    <!-- Sidebar -->
    <div class="hidden xl:block xl:w-80 flex-shrink-0">
      <Sidebar docs={allDocs} currentSlug={doc.slug} lang={lang} />
    </div>
    <!-- Mobile Sidebar (fixed overlay) -->
    <div class="xl:hidden absolute">
      <Sidebar docs={allDocs} currentSlug={doc.slug} lang={lang} />
    </div>

    <!-- Main Content -->
    <main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 xl:pl-8 pb-20 sm:pb-8">
      <div class="mx-auto max-w-3xl">
        <!-- Breadcrumbs -->
        <nav class="mb-8 text-sm" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-2 text-dark-text-secondary flex-wrap">
            <li><a href={`${langPrefix}/`} class="hover:text-brand-primary transition-colors">Home</a></li>
            <li class="flex items-center">
              <svg class="h-4 w-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <a href={`${langPrefix}/docs/getting-started/overview`} class="hover:text-brand-primary transition-colors">Docs</a>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-dark-text-primary">{title}</span>
            </li>
          </ol>
        </nav>

        <!-- Article -->
        <article class="prose prose-invert prose-brand max-w-none">
          <slot />
        </article>

        <!-- Page Navigation -->
        <div class="mt-12 pt-8 border-t border-dark-border flex justify-between">
          <div>
            <!-- Previous page link will go here -->
          </div>
          <div>
            <!-- Next page link will go here -->
          </div>
        </div>
      </div>
    </main>

    <!-- Table of Contents (desktop only) -->
    {headings.length > 0 && (
      <aside class="hidden xl:block xl:w-64 flex-shrink-0">
        <div class="sticky top-20 py-8 px-4">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  /* Prose styling for documentation content */
  .prose-brand {
    --tw-prose-body: #e8e8ee;
    --tw-prose-headings: #e8e8ee;
    --tw-prose-links: #6366f1;
    --tw-prose-bold: #e8e8ee;
    --tw-prose-code: #6366f1;
    --tw-prose-pre-bg: rgba(26, 26, 31, 0.8);
    --tw-prose-pre-code: #e8e8ee;
    --tw-prose-quotes: #a0a0b0;
    --tw-prose-quote-borders: #6366f1;
  }

  /* Adjust prose styles for code blocks */
  .prose :where(pre):not(:where([class~="not-prose"] *)) {
    background-color: rgba(26, 26, 31, 0.8);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 0.5rem;
  }

  .prose :where(code):not(:where([class~="not-prose"] *)) {
    background-color: rgba(99, 102, 241, 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-weight: 500;
  }

  .prose :where(pre code):not(:where([class~="not-prose"] *)) {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
  }

  /* Add smooth scrolling behavior */
  html {
    scroll-behavior: smooth;
  }

  /* Ensure main content is properly spaced on mobile to avoid FAB overlap */
  @media (max-width: 1279px) {
    main {
      padding-bottom: 5rem;
    }
  }
</style>
