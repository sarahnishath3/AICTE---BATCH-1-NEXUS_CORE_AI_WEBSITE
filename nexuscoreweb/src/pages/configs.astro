---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfigGallery from '../components/react/ConfigGallery';
import ConfigValidator from '../components/react/ConfigValidator';
import { fetchConfigs } from '../utils/api';

export const prerender = false;

const configs = await fetchConfigs();
---

<BaseLayout
  title="Configuration Gallery | Nexus Core"
  description="Browse and download 27 production-ready configurations for Nexus Core. Convert documentation, GitHub repos, and PDFs into Claude AI skills with pre-built configs."
>
  <!-- Config Gallery -->
  <ConfigGallery client:load initialConfigs={configs} />

  <!-- Submit Config Section -->
  <section class="py-20 bg-[#0A0A0F] border-t border-[#1F1F29]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4" style="font-family: 'Space Grotesk', sans-serif;">
          <span class="bg-gradient-to-r from-[#00A3E0] to-[#00D4AA] bg-clip-text text-transparent">
            Share Your Config
          </span>
        </h2>
        <p class="text-xl text-[#94A3B8] max-w-3xl mx-auto" style="font-family: 'Inter', sans-serif;">
          Created a config for a framework not listed here? Share it with the community!
        </p>
      </div>

      <!-- Info Banner -->
      <div class="max-w-4xl mx-auto mb-12">
        <div class="bg-gradient-to-r from-[#00A3E0]/10 to-[#00D4AA]/10 border border-[#00A3E0]/30 rounded-xl p-8">
          <div class="flex flex-col md:flex-row items-start md:items-center gap-6">
            <div class="flex-shrink-0 text-5xl">
              📤
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-semibold text-white mb-2" style="font-family: 'Space Grotesk', sans-serif;">How to Submit</h3>
              <ol class="text-[#94A3B8] space-y-2" style="font-family: 'Inter', sans-serif;">
                <li class="flex items-start">
                  <span class="text-[#00A3E0] mr-2">1.</span>
                  <span>Validate your config using the tool below</span>
                </li>
                <li class="flex items-start">
                  <span class="text-[#00A3E0] mr-2">2.</span>
                  <span>Click "Copy & Submit to GitHub" when valid</span>
                </li>
                <li class="flex items-start">
                  <span class="text-[#00A3E0] mr-2">3.</span>
                  <span>Paste your config in the GitHub issue that opens</span>
                </li>
                <li class="flex items-start">
                  <span class="text-[#00A3E0] mr-2">4.</span>
                  <span>We'll review and add it to the official gallery!</span>
                </li>
              </ol>
            </div>
            <div class="flex-shrink-0">
              <a
                href="/docs/guides/submit-config"
                class="inline-flex items-center px-6 py-3 bg-[#13131A] hover:bg-[#1F1F29] border border-[#1F1F29] rounded-lg text-sm font-medium text-white transition-all duration-300 hover:scale-105"
                style="font-family: 'Inter', sans-serif;"
              >
                📖 Detailed Guide
                <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Validator -->
      <ConfigValidator client:load />

      <!-- Additional Info -->
      <div class="max-w-4xl mx-auto mt-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="text-center p-6 bg-[#13131A] border border-[#1F1F29] rounded-lg">
            <div class="text-3xl mb-3">⚡</div>
            <h4 class="font-semibold text-white mb-2" style="font-family: 'Space Grotesk', sans-serif;">Quick Review</h4>
            <p class="text-sm text-[#94A3B8]" style="font-family: 'Inter', sans-serif;">
              We review submissions within 24-48 hours
            </p>
          </div>
          <div class="text-center p-6 bg-[#13131A] border border-[#1F1F29] rounded-lg">
            <div class="text-3xl mb-3">✅</div>
            <h4 class="font-semibold text-white mb-2" style="font-family: 'Space Grotesk', sans-serif;">Quality Checked</h4>
            <p class="text-sm text-[#94A3B8]" style="font-family: 'Inter', sans-serif;">
              All configs are tested before adding
            </p>
          </div>
          <div class="text-center p-6 bg-[#13131A] border border-[#1F1F29] rounded-lg">
            <div class="text-3xl mb-3">🎉</div>
            <h4 class="font-semibold text-white mb-2" style="font-family: 'Space Grotesk', sans-serif;">Get Credit</h4>
            <p class="text-sm text-[#94A3B8]" style="font-family: 'Inter', sans-serif;">
              Your GitHub profile listed as contributor
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
