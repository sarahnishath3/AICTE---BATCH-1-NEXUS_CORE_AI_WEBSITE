---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdminDashboard from '../components/react/AdminDashboard';

// Check if user is authenticated
const authCookie = Astro.cookies.get('gh_admin_session');
let isAuthenticated = false;
let userData = null;

if (authCookie) {
  try {
    userData = JSON.parse(atob(authCookie.value));
    isAuthenticated = true;
  } catch (e) {
    // Invalid cookie
    isAuthenticated = false;
  }
}

// Check for error messages from OAuth flow
const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');

let errorMessage = '';
if (error === 'not_authorized') {
  errorMessage = 'You are not authorized to access this page. Only admins can access the dashboard.';
} else if (error === 'auth_failed') {
  errorMessage = 'Authentication failed. Please try again.';
} else if (error === 'invalid_state') {
  errorMessage = 'Invalid authentication state. Please try again.';
}
---

<BaseLayout
  title="Admin Dashboard | Nexus Core"
  description="Admin dashboard for reviewing and approving config submissions"
>
  <div class="min-h-screen bg-dark-bg py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      {!isAuthenticated ? (
        <!-- Login Page -->
        <div class="max-w-md mx-auto">
          <div class="bg-dark-surface border border-dark-border rounded-xl p-8 text-center">
            <div class="mb-6">
              <svg class="h-16 w-16 mx-auto text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>

            <h1 class="text-3xl font-bold mb-4">Admin Dashboard</h1>
            <p class="text-dark-text-secondary mb-6">
              Sign in with your GitHub account to access the admin panel
            </p>

            {errorMessage && (
              <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm">
                {errorMessage}
              </div>
            )}

            <a
              href="/api/auth/github"
              class="inline-flex items-center space-x-3 px-6 py-3 bg-gradient-to-r from-brand-primary to-brand-secondary text-white font-semibold rounded-lg shadow-lg shadow-brand-primary/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-brand-primary/60"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
              <span>Sign in with GitHub</span>
            </a>

            <p class="mt-6 text-sm text-dark-text-secondary">
              Only authorized administrators can access this page
            </p>
          </div>
        </div>
      ) : (
        <!-- Authenticated - Show Dashboard -->
        <div>
          <!-- Header -->
          <div class="mb-8 flex items-center justify-between">
            <div>
              <h1 class="text-4xl font-bold mb-2">Admin Dashboard</h1>
              <p class="text-dark-text-secondary">Review and manage config submissions</p>
            </div>

            <div class="flex items-center space-x-4">
              <div class="flex items-center space-x-3 px-4 py-2 bg-dark-surface border border-dark-border rounded-lg">
                <img src={userData.avatarUrl} alt={userData.username} class="h-8 w-8 rounded-full" />
                <span class="text-sm font-medium">{userData.username}</span>
              </div>

              <a
                href="/api/auth/logout"
                class="px-4 py-2 text-sm text-dark-text-secondary hover:text-brand-primary transition-colors border border-dark-border hover:border-brand-primary rounded-lg"
              >
                Logout
              </a>
            </div>
          </div>

          <!-- Dashboard Component -->
          <AdminDashboard client:load />
        </div>
      )}
    </div>
  </div>
</BaseLayout>
