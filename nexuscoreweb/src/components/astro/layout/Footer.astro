---
// Footer with links and social
import { getLangFromUrl, getTranslations } from '../../../i18n/utils';

interface Props {
  hasDocsSidebar?: boolean;
}

const { hasDocsSidebar = false } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const footerLinks = {
  [t.footer.sections.product.title]: [
    { label: t.footer.sections.product.links.features, href: '/docs/getting-started/overview' },
    { label: t.footer.sections.product.links.configs, href: '/configs' },
    { label: t.footer.sections.product.links.docs, href: '/docs/getting-started/overview' },
    { label: t.footer.sections.product.links.architecture, href: '/architecture' },
    { label: t.footer.sections.product.links.api, href: '/api-docs' },
  ],
  [t.footer.sections.resources.title]: [
    { label: t.footer.sections.resources.links.gettingStarted, href: '/docs/getting-started/installation' },
    { label: t.footer.sections.resources.links.quickStart, href: '/docs/getting-started/quick-start' },
    { label: t.footer.sections.resources.links.installation, href: '/docs/getting-started/installation' },
    { label: t.footer.sections.resources.links.overview, href: '/docs/getting-started/overview' },
  ],
  [t.footer.sections.community.title]: [
    { label: t.footer.sections.community.links.github, href: 'https://github.com/yusufkaraaslan/Nexus_Core' },
    { label: t.footer.sections.community.links.issues, href: 'https://github.com/yusufkaraaslan/Nexus_Core/issues' },
    { label: t.footer.sections.community.links.pypi, href: 'https://pypi.org/project/nexus-core/' },
    { label: t.footer.sections.community.links.board, href: 'https://github.com/users/yusufkaraaslan/projects/2' },
  ],
};

const currentYear = new Date().getFullYear();
const copyright = t.footer.copyright.replace('{year}', currentYear.toString());
---

<footer class={`relative z-[60] border-t border-dark-border bg-dark-surface ${hasDocsSidebar ? 'xl:ml-64' : ''}`}>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8 [&>*]:border-0">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center space-x-3 text-xl font-bold mb-4 group">
          {/* Small Code Weaver Icon */}
          <svg class="h-8 w-8" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="footer-gradient-1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#00a3e0"/>
                <stop offset="100%" stop-color="#00d4aa"/>
              </linearGradient>
              <linearGradient id="footer-gradient-2" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#00d4aa"/>
                <stop offset="100%" stop-color="#38bdf8"/>
              </linearGradient>
            </defs>
            {/* Strand 1 */}
            <path d="M60 40 L80 40 L80 60 L60 60 Z" fill="url(#footer-gradient-1)" opacity="0.9"/>
            <path d="M80 60 L100 60 L120 80 L120 100 L100 100 L80 80 Z" fill="url(#footer-gradient-1)" opacity="0.9"/>
            <path d="M120 100 L140 100 L160 120 L160 140 L140 140 L120 120 Z" fill="url(#footer-gradient-1)" opacity="0.9"/>
            <path d="M160 140 L180 140 L180 160 L160 160 Z" fill="url(#footer-gradient-1)" opacity="0.9"/>
            {/* Strand 2 */}
            <rect x="85" y="40" width="30" height="15" rx="3" fill="url(#footer-gradient-2)" opacity="0.95"/>
            <rect x="85" y="85" width="50" height="12" rx="2" fill="url(#footer-gradient-2)" opacity="0.9"/>
            <rect x="85" y="102" width="40" height="12" rx="2" fill="url(#footer-gradient-2)" opacity="0.85"/>
            <rect x="125" y="125" width="50" height="12" rx="2" fill="url(#footer-gradient-2)" opacity="0.9"/>
            <rect x="145" y="170" width="30" height="15" rx="3" fill="url(#footer-gradient-2)" opacity="0.95"/>
            {/* Nodes */}
            <circle cx="75" cy="70" r="6" fill="#00a3e0" opacity="0.9"/>
            <circle cx="115" cy="110" r="6" fill="#00d4aa" opacity="0.9"/>
            <circle cx="155" cy="150" r="6" fill="#38bdf8" opacity="0.9"/>
            <circle cx="170" cy="175" r="6" fill="#00a3e0" opacity="0.9"/>
          </svg>
          <span class="bg-gradient-to-r from-ocean-600 to-ocean-500 bg-clip-text text-transparent">
            Nexus Core
          </span>
        </a>
        <p class="text-sm text-dark-text-secondary mb-4">
          {t.footer.tagline}
        </p>
        <!-- Stats Badge -->
        <div class="flex items-center space-x-2 text-xs text-dark-text-secondary">
          <span class="flex items-center space-x-1">
            <svg class="h-4 w-4 text-ocean-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>{t.footer.stats.tests}</span>
          </span>
          <span class="text-ocean-500">•</span>
          <span>v3.5.0</span>
        </div>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h3 class="text-sm font-semibold text-dark-text-primary mb-4">{category}</h3>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-dark-text-secondary hover:text-ocean-500 transition-colors"
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Section -->
    <div class="pt-8 border-t border-dark-border flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
      <p class="text-sm text-dark-text-secondary">
        {copyright} <a href="https://astro.build" class="text-ocean-500 hover:text-ocean-400">Astro</a>.
      </p>

      <!-- Social Links -->
      <div class="flex items-center space-x-6">
        <a
          href="https://github.com/yusufkaraaslan/Nexus_Core"
          class="text-dark-text-secondary hover:text-ocean-500 transition-colors"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href="https://pypi.org/project/nexus-core/"
          class="text-dark-text-secondary hover:text-ocean-500 transition-colors"
          aria-label="PyPI"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm0 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10-4.5 10-10 10z"/>
            <path d="M7.5 9.5h9v5h-9z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
