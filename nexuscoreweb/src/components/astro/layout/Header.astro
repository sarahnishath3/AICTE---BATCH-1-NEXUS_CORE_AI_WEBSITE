---
// Navigation header with logo and menu
import LanguageSwitcher from '../../react/LanguageSwitcher';
import { getLangFromUrl, getTranslations } from '../../../i18n/utils';

const currentPath = Astro.url.pathname;
const currentLang = getLangFromUrl(Astro.url);
const t = getTranslations(currentLang);

// Add language prefix to internal links if on Chinese site
const langPrefix = currentLang === 'zh' ? '/zh' : '';

const navLinks = [
  { href: `${langPrefix}/`, label: t.nav.home },
  { href: `${langPrefix}/configs`, label: t.nav.configs },
  { href: `${langPrefix}/docs/getting-started/overview`, label: t.nav.docs },
  { href: `${langPrefix}/architecture`, label: t.nav.architecture },
  { href: `${langPrefix}/blog`, label: t.nav.blog },
];
---

<header class="sticky top-0 z-50 w-full border-b border-dark-border bg-dark-bg/80 backdrop-blur-lg">
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 text-xl font-bold group">
        <img 
          src="/logo.png" 
          alt="Nexus Core Logo" 
          class="h-11 w-11 sm:h-12 sm:w-12 lg:h-14 lg:w-14 object-contain"
        />
        <span class="bg-gradient-to-r from-ocean-600 to-ocean-500 bg-clip-text text-transparent">
          Nexus Core
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex md:items-center md:space-x-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-ocean-500',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-ocean-500'
                : 'text-dark-text-secondary',
            ]}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}

        <!-- Language Switcher -->
        <LanguageSwitcher client:load currentLang={currentLang} currentPath={currentPath} />

        <!-- CTA Button -->
        <a
          href={`${langPrefix}/docs/getting-started/installation`}
          class="rounded-lg bg-gradient-to-r from-ocean-600 to-ocean-500 px-4 py-2 text-sm font-semibold text-white transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-ocean-500 focus:ring-offset-2 focus:ring-offset-dark-bg shadow-lg shadow-ocean-500/20"
        >
          {t.nav.getStarted}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden rounded-lg p-2 text-dark-text-secondary hover:bg-dark-surface hover:text-dark-text-primary focus:outline-none focus:ring-2 focus:ring-ocean-500"
        aria-label="Toggle mobile menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4"
    >
      <div class="flex flex-col space-y-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'bg-ocean-500/10 text-ocean-500'
                : 'text-dark-text-secondary hover:bg-dark-surface hover:text-dark-text-primary',
            ]}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
        <!-- Language Switcher Mobile -->
        <div class="px-3 py-2">
          <LanguageSwitcher client:load currentLang={currentLang} currentPath={currentPath} />
        </div>
        <a
          href={`${langPrefix}/docs/getting-started/installation`}
          class="rounded-lg bg-gradient-to-r from-ocean-600 to-ocean-500 px-3 py-2 text-center text-sm font-semibold text-white"
        >
          {t.nav.getStarted}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu when clicking outside
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    if (!button?.contains(target) && !menu?.contains(target)) {
      menu?.classList.add('hidden');
    }
  });
</script>
