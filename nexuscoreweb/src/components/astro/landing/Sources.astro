---
// Sources and Formats showcase section
import { getLangFromUrl, getTranslations } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const isZh = lang === 'zh';

const primarySources = [
  { icon: '🌐', name: isZh ? '文档网站' : 'Documentation', desc: isZh ? '任何文档站点，支持 SPA 浏览器渲染' : 'Any doc site, with SPA browser rendering' },
  { icon: '🐙', name: isZh ? 'GitHub 仓库' : 'GitHub Repos', desc: isZh ? '公共和私有仓库，带 AST 分析' : 'Public & private repos, with AST analysis' },
  { icon: '📄', name: isZh ? 'PDF 文件' : 'PDF Files', desc: isZh ? '扫描文档、手册、带有 OCR 的研究论文' : 'Scanned docs, manuals, research papers with OCR' },
  { icon: '💻', name: isZh ? '本地代码库' : 'Local Codebases', desc: isZh ? '27+ 语言，C3.x 深度分析' : '27+ languages, C3.x deep analysis' },
  { icon: '🎬', name: isZh ? '视频' : 'Video', desc: isZh ? 'YouTube、本地视频，带 OCR 代码提取' : 'YouTube, local videos, with OCR code extraction' },
  { icon: '📓', name: isZh ? 'Jupyter 笔记本' : 'Jupyter Notebooks', desc: isZh ? '代码单元格、输出、Markdown 提取' : 'Code cells, outputs, markdown extraction' },
];

const additionalSources = [
  { icon: '📝', name: isZh ? 'Word' : 'Word (.docx)' },
  { icon: '📚', name: isZh ? 'EPUB' : 'EPUB' },
  { icon: '🔌', name: isZh ? 'OpenAPI' : 'OpenAPI/Swagger' },
  { icon: '📑', name: isZh ? 'AsciiDoc' : 'AsciiDoc' },
  { icon: '📊', name: isZh ? 'PowerPoint' : 'PowerPoint' },
  { icon: '🌍', name: isZh ? '本地 HTML' : 'Local HTML' },
  { icon: '📡', name: isZh ? 'RSS/Atom' : 'RSS/Atom' },
  { icon: '📖', name: isZh ? 'Man 手册' : 'Man Pages' },
  { icon: '🏢', name: 'Confluence' },
  { icon: '📋', name: 'Notion' },
  { icon: '💬', name: isZh ? 'Slack/Discord' : 'Slack/Discord' },
];

const outputFormats = [
  { category: isZh ? 'AI 技能' : 'AI Skills', items: ['Claude', 'Gemini', 'OpenAI', 'Kimi', 'DeepSeek', 'Qwen', 'OpenRouter', 'Together', 'Fireworks', 'MiniMax', 'OpenCode'], color: 'ocean' },
  { category: isZh ? 'RAG / 向量' : 'RAG / Vectors', items: ['LangChain', 'LlamaIndex', 'Pinecone', 'Chroma', 'FAISS', 'Haystack', 'Qdrant', 'Weaviate'], color: 'ocean' },
  { category: isZh ? 'AI 编码' : 'AI Coding', items: ['Cursor', 'Windsurf', 'Cline', 'Continue.dev', 'Roo', 'Aider', 'Bolt', 'Kilo'], color: 'ocean' },
  { category: isZh ? '通用' : 'Generic', items: ['Markdown', 'JSON', 'YAML'], color: 'ocean' },
];
---

<section class="py-20 bg-dark-bg relative overflow-hidden">
  {/* Background glow */}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-ocean-500/5 rounded-full blur-3xl -z-10"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center mb-16">
      <h2 class="text-4xl font-bold mb-6 text-dark-text-primary">
        {isZh ? '18 种源 → 任何 AI 系统' : '18 Sources → Any AI System'}
      </h2>
      <p class="text-xl text-dark-text-secondary">
        {isZh
          ? '一个工具统一您的所有 AI 技能和 RAG 需求'
          : 'One tool for AI skills and RAG from any source'}
      </p>
    </div>

    <!-- Primary Input Sources -->
    <div class="max-w-6xl mx-auto mb-8">
      <h3 class="text-2xl font-semibold mb-8 text-center text-dark-text-primary">
        {isZh ? '输入源' : 'Input Sources'}
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {primarySources.map(source => (
          <div class="bg-dark-surface rounded-2xl p-6 border border-dark-border hover:border-ocean-500/50 transition-all duration-300 hover:shadow-xl hover:shadow-ocean-500/10 group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-ocean-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="relative">
              <div class="w-14 h-14 rounded-xl bg-ocean-500/10 flex items-center justify-center text-3xl mb-4 group-hover:scale-110 transition-transform duration-300">
                {source.icon}
              </div>
              <h4 class="text-lg font-semibold mb-2 text-dark-text-primary">{source.name}</h4>
              <p class="text-sm text-dark-text-secondary">{source.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Additional Sources -->
    <div class="max-w-4xl mx-auto mb-20">
      <div class="flex flex-wrap justify-center gap-3">
        {additionalSources.map(source => (
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-dark-surface rounded-full text-sm text-dark-text-primary border border-dark-border hover:border-ocean-500/30 transition-colors cursor-default">
            <span>{source.icon}</span>
            <span>{source.name}</span>
          </span>
        ))}
      </div>
      <p class="text-center text-sm text-dark-text-muted mt-4">
        {isZh ? '共 18 种源类型，全部支持统一 create 命令和 MCP' : 'All 18 source types supported via unified create command and MCP'}
      </p>
    </div>

    {/* Arrow */}
    <div class="flex justify-center mb-12">
      <div class="w-16 h-16 rounded-full bg-gradient-to-r from-ocean-600 to-ocean-500 flex items-center justify-center animate-glow-pulse shadow-lg shadow-ocean-500/30">
        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>

    <!-- Output Formats -->
    <div class="max-w-6xl mx-auto">
      <h3 class="text-2xl font-semibold mb-8 text-center text-dark-text-primary">
        {isZh ? '12+ AI 平台输出' : '12+ AI Platform Outputs'}
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {outputFormats.map(format => (
          <div class="bg-dark-surface rounded-2xl p-6 border border-dark-border hover:border-ocean-500/30 transition-all duration-300 group">
            <h4 class="text-lg font-semibold mb-4 text-ocean-500 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-ocean-500"></span>
              {format.category}
            </h4>
            <div class="flex flex-wrap gap-2">
              {format.items.map(item => (
                <span class="px-3 py-1.5 bg-dark-bg rounded-full text-sm text-dark-text-primary border border-dark-border group-hover:border-ocean-500/20 transition-colors hover:bg-ocean-500/10 hover:text-ocean-400 cursor-default">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* Code Example */}
    <div class="max-w-4xl mx-auto mt-16">
      <div class="bg-dark-surface rounded-2xl border border-dark-border overflow-hidden shadow-xl shadow-ocean-500/5">
        <div class="flex items-center justify-between px-4 py-3 bg-dark-bg border-b border-dark-border">
          <span class="text-sm text-dark-text-secondary flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-ocean-500"></span>
            {isZh ? '示例：任何源 → 任何 AI 平台' : 'Example: Any Source → Any AI Platform'}
          </span>
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
        </div>
        <div class="p-6 font-mono text-sm overflow-x-auto">
          <div class="text-dark-text-secondary"># {isZh ? '从任何源创建技能' : 'Create skill from any source'}</div>
          <div class="text-dark-text-primary">$ <span class="text-ocean-500">nexus-core</span> create https://react.dev</div>
          <div class="text-dark-text-primary">$ <span class="text-ocean-500">nexus-core</span> create facebook/react</div>
          <div class="text-dark-text-primary">$ <span class="text-ocean-500">nexus-core</span> create manual.pdf</div>
          <div class="text-dark-text-secondary mt-2"># {isZh ? '导出到任何 AI 平台' : 'Export to any AI platform'}</div>
          <div class="text-dark-text-primary">$ <span class="text-ocean-500">nexus-core</span> package output/react --target claude</div>
          <div class="text-dark-text-primary">$ <span class="text-ocean-500">nexus-core</span> package output/react --target langchain</div>
          <div class="text-dark-text-secondary mt-2"># {isZh ? '使用不同的 AI 代理进行增强' : 'Use a different AI agent for enhancement'}</div>
          <div class="text-dark-text-primary">$ <span class="text-ocean-500">nexus-core</span> create https://react.dev --agent kimi</div>
        </div>
      </div>
    </div>
  </div>
</section>
