---
// Stats section with key metrics
import { getLangFromUrl, getTranslations } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

// Fetch GitHub stats at build time
let githubStars = '0';
let githubForks = '0';
let githubContributors = '0';

try {
  const response = await fetch('https://api.github.com/repos/yusufkaraaslan/Nexus_Core');
  if (response.ok) {
    const data = await response.json();
    githubStars = data.stargazers_count.toLocaleString();
    githubForks = data.forks_count.toLocaleString();
  }

  // Fetch contributors count
  const contributorsResponse = await fetch('https://api.github.com/repos/yusufkaraaslan/Nexus_Core/contributors');
  if (contributorsResponse.ok) {
    const contributors = await contributorsResponse.json();
    githubContributors = contributors.length.toString();
  }
} catch (error) {
  console.error('Failed to fetch GitHub stats:', error);
}

const stats = [
  {
    value: githubStars,
    label: t.stats.labels.stars,
    icon: '⭐',
    color: '#f59e0b', // amber - keep for contrast
  },
  {
    value: githubForks,
    label: t.stats.labels.forks,
    icon: '🍴',
    color: '#00a3e0', // ocean blue
  },
  {
    value: githubContributors,
    label: t.stats.labels.contributors,
    icon: '👥',
    color: '#00d4aa', // ocean cyan
  },
  {
    value: t.stats.values.tests,
    label: t.stats.labels.tests,
    icon: '✅',
    color: '#10b981', // green - keep
  },
  {
    value: t.stats.values.platforms,
    label: t.stats.labels.platforms,
    icon: '🤖',
    color: '#00a3e0', // ocean blue
  },
  {
    value: t.stats.values.mcpTools,
    label: t.stats.labels.mcpTools,
    icon: '🔧',
    color: '#00d4aa', // ocean cyan
  },
];
---

<section class="py-20 bg-dark-surface border-y border-dark-border relative overflow-hidden">
  {/* Background glow */}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-ocean-500/5 rounded-full blur-3xl -z-10"></div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center mb-16">
      <h2 class="text-4xl font-bold mb-4 text-dark-text-primary">
        {t.stats.title}
      </h2>
      <p class="text-xl text-dark-text-secondary">
        {t.stats.subtitle}
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {stats.map((stat, index) => (
        <div
          class="group text-center p-6 rounded-2xl transition-all duration-300 hover:bg-dark-bg hover:shadow-xl hover:shadow-ocean-500/10 hover:-translate-y-1 border border-transparent hover:border-ocean-500/20"
          style={`animation-delay: ${index * 100}ms`}
        >
          {/* Icon */}
          <div class="mb-3 text-4xl transition-transform duration-300 group-hover:scale-125 group-hover:rotate-12">
            {stat.icon}
          </div>

          {/* Value */}
          <div class="text-3xl font-bold mb-2" style={`color: ${stat.color}`}>
            {stat.value}
          </div>

          {/* Label */}
          <div class="text-sm text-dark-text-secondary group-hover:text-dark-text-primary transition-colors">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom Banner -->
    <div class="mt-16 text-center">
      <p class="text-dark-text-secondary mb-6 text-lg">
        {t.stats.banner}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="https://github.com/yusufkaraaslan/Nexus_Core"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center space-x-2 px-6 py-3 rounded-xl border border-dark-border bg-dark-bg text-sm font-medium text-dark-text-secondary hover:text-ocean-500 hover:border-ocean-500 hover:bg-ocean-500/5 transition-all duration-300 hover:shadow-lg hover:shadow-ocean-500/20"
        >
          <svg class="h-5 w-5 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          <span>{t.stats.cta.star}</span>
        </a>
        <a
          href="https://pypi.org/project/nexus-core/"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center space-x-2 px-6 py-3 rounded-xl border border-dark-border bg-dark-bg text-sm font-medium text-dark-text-secondary hover:text-ocean-500 hover:border-ocean-500 hover:bg-ocean-500/5 transition-all duration-300 hover:shadow-lg hover:shadow-ocean-500/20"
        >
          <svg class="h-5 w-5 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm0 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10-4.5 10-10 10z"/>
            <path d="M7.5 9.5h9v5h-9z"/>
          </svg>
          <span>{t.stats.cta.download}</span>
        </a>
      </div>
    </div>
  </div>
</section>
